[
  {
    "id": 1,
    "priority": 1,
    "action": {
      "type": "redirect",
      "redirect": {
        "transform": {
          "queryTransform": {
            "addOrReplaceParams": [
              {
                "key": "hl",
                "value": "en-US"
              }
            ]
          }
        }
      }
    },
    "condition": {
      "regexFilter": "^https://[^\\\\.]*\\\\.(google\\\\.com|recaptcha\\\\.net)/recaptcha",
      "resourceTypes": [
        "sub_frame"
      ]
    }
  },
  {
    "id": 2,
    "priority": 1,
    "action": {
      "type": "modifyHeaders",
      "responseHeaders": [
        {
          "header": "content-security-policy",
          "operation": "remove"
        },
        {
          "header": "content-security-policy-report-only",
          "operation": "remove"
        }
      ]
    },
    "condition": {
      "urlFilter": "*://*.stripe.com/*",
      "resourceTypes": [
        "main_frame",
        "sub_frame",
        "script",
        "xmlhttprequest"
      ]
    }
  },
  {
    "id": 3,
    "priority": 1,
    "action": {
      "type": "modifyHeaders",
      "responseHeaders": [
        {
          "header": "content-security-policy",
          "operation": "remove"
        },
        {
          "header": "content-security-policy-report-only",
          "operation": "remove"
        }
      ]
    },
    "condition": {
      "urlFilter": "*://*.hcaptcha.com/*",
      "resourceTypes": [
        "main_frame",
        "sub_frame",
        "script"
      ]
    }
  }
]